[sub_resource type="GDScript" id="GDScript_inxo1"]
script/source = "extends Node2D

@onready var dialog_holder: Node2D = $DialogHolder
@onready var dialog_box: Control = $DialogHolder/dialog_box

var player_ref: Node2D = null
var offset_balao: Vector2 = Vector2(140, -180)

func _ready() -> void:
	dialog_holder.scale = Vector2(0.5, 0.5)
d	dialog_box.hide()

	var players: Array = get_tree().get_nodes_in_group(\"player\")
	if players.size() > 0:
		player_ref = players[0] as Node2D
	else:
		print(\"Nenhum player encontrado no grupo 'player'.\")

func _process(_delta: float) -> void:
	if player_ref == null:
		return

	if dialog_box.visible:
		var largura_balao: float = dialog_box.size.x * dialog_holder.scale.x
		var pos_x: float = player_ref.global_position.x - (largura_balao / 2.0) + offset_balao.x
		var pos_y: float = player_ref.global_position.y + offset_balao.y

		dialog_holder.global_position = Vector2(pos_x, pos_y)

func _on_area_2d_e_fala_1_body_entered(body: Node2D) -> void:
	if not body.is_in_group(\"player\"):
		return

	await dialog_box.mostrar_texto(\"Faz tempo que eu não venho nessa floresta... Onde você está filha?\")

func _on_area_2d_s_fala_1_body_entered(body: Node2D) -> void:
	if not body.is_in_group(\"player\"):
		return

	await dialog_box.esconder_balao()
"

