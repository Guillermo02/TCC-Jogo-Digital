[sub_resource type="GDScript" id="GDScript_g88wp"]
script/source = "extends Area2D

@export var nome_fio: String = \"1\"
@export var par_nome: String = \"A\"

@export var sprite_normal: Texture2D
@export var sprite_pressionado: Texture2D
@export var sprite_conectado: Texture2D

var conectado: bool = false

@onready var sprite: Sprite2D = $Sprite2D

func _ready() -> void:
	process_mode = Node.PROCESS_MODE_ALWAYS
	input_pickable = true
	definir_normal()

func _input_event(_viewport, event, _shape_idx) -> void:
	if conectado:
		return

	if event is InputEventMouseButton:
		if event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
			print(\"Clique no fio: \", name)

			var puzzle = get_tree().get_first_node_in_group(\"puzzle_descida\")

			if puzzle != null and puzzle.has_method(\"selecionar_ponto\"):
				puzzle.selecionar_ponto(self)
			else:
				print(\"Erro: PuzzleDescida não encontrado ou sem selecionar_ponto().\")

func definir_normal() -> void:
	if sprite_normal != null:
		sprite.texture = sprite_normal

	modulate = Color(1, 1, 1)

func definir_pressionado() -> void:
	if sprite_pressionado != null:
		sprite.texture = sprite_pressionado

	modulate = Color(1, 1, 1)

func definir_conectado() -> void:
	if sprite_conectado != null:
		sprite.texture = sprite_conectado

	modulate = Color(1, 1, 1)

func _on_mouse_entered() -> void:
	if not conectado:
		modulate = Color(1.15, 1.15, 1.15)

func _on_mouse_exited() -> void:
	if not conectado:
		modulate = Color(1, 1, 1)
"

[sub_resource type="RectangleShape2D" id="RectangleShape2D_fvtmu"]
size = Vector2(54, 52)

